# Server
PORT=4000
NODE_ENV=development

# Mistral AI
MISTRAL_API_KEY=your_mistral_api_key_here

# Pinecone - UN SEUL INDEX avec namespaces par agent
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX_NAME=corevia-medical
# Optionnel: host data-plane (visible dans la console Pinecone, champ "Host").
# Utile si l'API renvoie 404 sur `https://api.pinecone.io/indexes/<name>` (index introuvable ou mauvais projet).
# Exemple: https://corevia-medecin-generaliste-pp36lde.svc.aped-4627-b74a.pinecone.io
PINECONE_INDEX_HOST=

# Logging
LOG_LEVEL=info
